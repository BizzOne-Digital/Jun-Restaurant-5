# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb://127.0.0.1:27017/ono-poke-bar

# NextAuth — generate a long random secret for production
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Public site URL — used for Stripe Checkout success/cancel redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — use test keys locally; never commit live secrets; keys must be sk_… / pk_… (not mk_…)
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional Phase 2 — Stripe Connect destination account (must start with acct_)
# NOTE: For ONO Poké Bar this is now hardcoded in lib/payment-config.ts — do not set here.
STRIPE_CONNECTED_ACCOUNT_ID=

# Stable id stored on Checkout Session metadata (multi-tenant hook)
RESTAURANT_ID=ono-poke-bar

# Restaurant inbox for paid-order notifications (falls back to SiteSetting.email in MongoDB)
RESTAURANT_ORDER_EMAIL=orders@example.com

# Optional BCC on Mailgun new-order email when different from RESTAURANT_ORDER_EMAIL
ADMIN_ORDER_EMAIL=

# CC on transactional order emails
ORDER_CC_EMAIL=junkong68@gmail.com

# Mailgun — set in .env.local / Vercel (never commit real API keys)
# The display name and the email logo are pulled from SiteSetting (admin → Settings),
# so emails are branded by the restaurant — not by a generic platform name.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=your-sending-domain.com
# Preferred: full RFC From header (overrides MAILGUN_FROM_EMAIL / MAILGUN_FROM_NAME when set)
MAILGUN_FROM="ONO Poké Bar <orders@your-sending-domain.com>"
# Optional split sender (used only if MAILGUN_FROM is unset).
# Leave MAILGUN_FROM_NAME empty to fall back to the restaurant display name.
MAILGUN_FROM_EMAIL=orders@your-sending-domain.com
MAILGUN_FROM_NAME=

# Legacy only when MAILGUN_API_KEY is unset — verified sender for Resend/SMTP
ORDER_FROM_EMAIL=orders@example.com
EMAIL_PROVIDER=resend_or_smtp
RESEND_API_KEY=your_resend_key_here

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Set to "false" to skip the customer confirmation email (kitchen email still sends when Mailgun is on)
# ORDER_SEND_CUSTOMER_CONFIRMATION=true

# Central Restaurant Order App integration
# POST paid orders to the central Order App after Stripe payment is confirmed.
# These are backend-only — never expose ORDER_APP_API_KEY to the browser.
ORDER_APP_API_URL=http://localhost:4000
ORDER_APP_RESTAURANT_KEY=ono_poke_bar
ORDER_APP_API_KEY=the_key_generated_from_control_panel
